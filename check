#!/bin/bash
#
# check — almostawake.com preflight. Reports which `n` dependencies are
# already installed on this machine and which `n` would install if run.
#
#   curl -fsSL https://almostawake.com/check | bash
#
# Read-only: no installs, no writes, no network beyond the detection
# probes copied from `n`. Likely throwaway — once `n` learns to print
# this itself, delete this file.
#
# Detection logic is DUPLICATED VERBATIM from `n`'s sections 1-4. Keep
# them in sync until this script goes away.

set -e

[ -t 1 ] && clear

IF_HOME="$HOME/.if"
NODE_VERSION="22.11.0"
JAVA_VERSION="21"

die() { printf 'error: %s\n' "$*" >&2; exit 1; }

# =====================================================================
# OS / ARCH DETECTION (from n)
# =====================================================================
detect_os_arch() {
  case "$(uname -s)" in
    Darwin) OS="darwin" ;;
    Linux)  OS="linux"  ;;
    *) die "unsupported OS: $(uname -s) — supports macOS and Linux only" ;;
  esac
  case "$(uname -m)" in
    arm64|aarch64) ARCH="arm64" ;;
    x86_64|amd64)  ARCH="x64"   ;;
    *) die "unsupported architecture: $(uname -m)" ;;
  esac
  export OS ARCH
}
detect_os_arch

# =====================================================================
# DETECT WHAT'S INSTALLED (from n)
# =====================================================================

have_git=false
if [ -x "$IF_HOME/git/bin/git" ]; then
  if [ -x "$IF_HOME/git/bin/git.real" ]; then
    have_git=true
  fi
else
  git_path="$(command -v git 2>/dev/null || true)"
  if [ -n "$git_path" ]; then
    case "$git_path" in
      /usr/bin/git)
        xcode-select -p >/dev/null 2>&1 && have_git=true
        ;;
      *) have_git=true ;;
    esac
  fi
fi

have_gh=false
if [ -x "$IF_HOME/gh/bin/gh" ]; then
  have_gh=true
elif command -v gh >/dev/null 2>&1; then
  have_gh=true
fi

have_jq=false
if [ -x "$IF_HOME/jq/bin/jq" ]; then
  have_jq=true
elif command -v jq >/dev/null 2>&1; then
  have_jq=true
fi

have_node22=false
node_bin=""
if   [ -x "$IF_HOME/node/bin/node" ]; then node_bin="$IF_HOME/node/bin/node"
elif command -v node >/dev/null 2>&1;  then node_bin="node"
fi
if [ -n "$node_bin" ]; then
  nm="$("$node_bin" -v 2>/dev/null | sed 's/v//' | cut -d. -f1)"
  [ -n "$nm" ] && [ "$nm" -ge 22 ] 2>/dev/null && have_node22=true
fi

have_java21=false
java_bin=""
if   [ -x "$IF_HOME/java/Contents/Home/bin/java" ]; then java_bin="$IF_HOME/java/Contents/Home/bin/java"
elif [ -x "$IF_HOME/java/bin/java" ];               then java_bin="$IF_HOME/java/bin/java"
elif command -v java >/dev/null 2>&1;               then java_bin="java"
fi
if [ -n "$java_bin" ]; then
  jm="$("$java_bin" -version 2>&1 | awk -F '"' '/version/ {print $2}' | cut -d. -f1)"
  [ -n "$jm" ] && [ "$jm" -ge 21 ] 2>/dev/null && have_java21=true
fi

have_claude=false
if   [ -x "$IF_HOME/claude/bin/claude" ]; then have_claude=true
elif command -v claude >/dev/null 2>&1;   then have_claude=true
fi

have_chrome=false
if [ "$OS" = "darwin" ]; then
  if { [ -d "$HOME/Applications/Chrome with Claude Code.app" ] || \
       [ -d "/Applications/Chrome with Claude Code.app" ]; } && \
     { [ -d "$HOME/Applications/Google Chrome.app" ] || \
       [ -d "/Applications/Google Chrome.app" ]; }; then
    have_chrome=true
  fi
fi

have_vscode=false
if [ "$OS" = "darwin" ] && \
   { [ -d "$HOME/Applications/Visual Studio Code.app" ] || \
     [ -d "/Applications/Visual Studio Code.app" ]; }; then
  have_vscode=true
fi

ITEMS=("git" "gh" "jq" "node 22" "java 21" "claude code [in YOLO mode]" "chrome [connected to Claude]" "vscode")
INSTALLED=("$have_git" "$have_gh" "$have_jq" "$have_node22" "$have_java21" "$have_claude" "$have_chrome" "$have_vscode")
N=${#ITEMS[@]}

N_TODO=0
for x in "${INSTALLED[@]}"; do [ "$x" = "false" ] && N_TODO=$((N_TODO + 1)); done

# =====================================================================
# REPORT
# =====================================================================
# Same row glyphs as `n` so the preview reads as a dry-run of what
# you'll see on the real install screen. ✓ = present, ○ = would install.

echo ""
echo "n dependency check ($OS $ARCH)"
echo ""
for i in $(seq 0 $((N - 1))); do
  if [ "${INSTALLED[$i]}" = "true" ]; then
    printf '✓     %s\n' "${ITEMS[$i]}"
  else
    printf '○     %s   (will install)\n' "${ITEMS[$i]}"
  fi
done
echo ""
if [ "$N_TODO" -eq 0 ]; then
  echo "all $N dependencies already installed — n would skip straight to project setup"
else
  echo "$N_TODO of $N would be installed if you run n"
fi
echo ""
