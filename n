# Row 0: browser sign-in. Opens a 1-line section showing a static
# message while node cmd-auth.mjs runs in the background. cmd-auth's
# own progress goes to log; the user's visible cue is the browser
# popping up.
_prov_signin() {
  # No section / no inline message. Browser pops up over the terminal
  # so the user already knows what to do. Row sits at "running"
  # (--->) until cmd-auth returns; then orchestrator flips it to ✓.
  local rc=0
  ( cd "$IF_HOME" && node cmd-auth.mjs ) >> "$INSTALL_LOG" 2>&1 || rc=$?
  if [ "$rc" -ne 0 ]; then return 1; fi
  [ -f "$IF_HOME/.env.auth.json" ] || return 1
  EMAIL=$(perl -MJSON::PP -e 'print decode_json(do { local $/; <STDIN> })->{email} // ""' < "$IF_HOME/.env.auth.json")
  ACCESS_TOKEN=$(perl -MJSON::PP -e 'print decode_json(do { local $/; <STDIN> })->{tokens}{access_token} // ""' < "$IF_HOME/.env.auth.json")
  [ -n "$EMAIL" ] && [ -n "$ACCESS_TOKEN" ] || return 1
  log "n: signed in as $EMAIL"
  # Pre-flight billing check, gated to before any project work.
  if ! preflight_check; then
    # Stash so provision_all can show the right hint after row goes ✗.
    PROV_SIGNIN_PREFLIGHT_FAIL="$PREFLIGHT_REASON"
    return 1
  fi
  return 0
}

# Row 1: create google cloud project. Opens a 2-line section
# (line 1: error or blank; line 2: prompt). Each iteration redraws
# both lines. On success closes the section; row label becomes
# "google cloud project created".
_prov_create() {
  PID=""
  PROV_CREATE_FATAL_MSG=""
  local proj_parent="${PROJECT_DIR:-$HOME/Projects}"
  # Reuse mode: no prompt, no section. Just verify the project exists
  # and adopt it. Downstream rows (enable APIs, configure auth, etc.)
  # are all idempotent so they're safe to re-run on an existing project.
  if [ -n "$REUSE_PROJECT_ID" ]; then
    if [ -e "$proj_parent/$REUSE_PROJECT_ID" ]; then
      PROV_CREATE_FATAL_MSG="you already have this project locally. delete it or use another name"
      return 1
    fi
    if ! project_exists "$REUSE_PROJECT_ID"; then
      PROV_CREATE_FATAL_MSG="project '$REUSE_PROJECT_ID' not found — pass an existing project id to --reuse-project"
      return 1
    fi
    PID="$REUSE_PROJECT_ID"
    return 0
  fi
  local row_i=1
  local up=$((PROV_N - row_i - 1))
  # 4-line section: prompt with arrow, error (or blank), blank, blank.
  # Error sits BELOW the prompt — same pattern as the warning loop:
  # the prompt stays anchored at the top of the section while errors
  # accumulate underneath as hints. Closing deletes all 4 lines.
  printf '\033[%dA\033[4L' "$up"
  # Cursor on line 1 (top).
  local candidate result combined
  while [ -z "$PID" ] && [ -z "$PROV_CREATE_FATAL_MSG" ]; do
    # Line 1: prompt.
    printf '\r\033[K  ->  choose a project id: '
    read -r candidate </dev/tty || candidate=""
    # `read` consumed enter — cursor on line 2 col 0. Back up to
    # line 1 so we can spinner-overwrite it if the input is valid.
    printf '\033[1A\r'
    if ! validate_gcp_project_id "$candidate"; then
      combined=$(IFS=', '; echo "${VALIDATION_ERRORS[*]}")
      # Print error on line 2, return cursor to line 1.
      printf '\033[1B\r\033[K      ✗  %s\033[1A\r' "$combined"
      continue
    fi
    # Local folder collision is fatal — the script's job is to create a
    # fresh project folder, so refuse to touch a pre-existing one.
    if [ -e "$proj_parent/$candidate" ]; then
      PROV_CREATE_FATAL_MSG="you already have this project locally. delete it or use another name"
      break
    fi
    # Spinner replaces the prompt on line 1 while we wait on the API.
    printf '\033[K  ->  creating %s' "$candidate"
    result=$(create_project "$candidate")
    printf '\r\033[K'                          # erase spinner; cursor at line 1 col 0
    case "$result" in
      ok)      PID="$candidate" ;;
      # Recoverable — show error on line 2 and let the user try again.
      taken)   printf '\033[1B\r\033[K      ✗  %s is taken\033[1A\r' "$candidate" ;;
      # Everything else is fatal in this session — bail out, let the
      # orchestrator print at the bottom and exit. Specific known
      # cases first; `*` catches anything we forgot. (Order matters:
      # `*` MUST be last in a bash case statement.)
      quota)   PROV_CREATE_FATAL_MSG="account project limit reached — delete an unused project at console.cloud.google.com" ;;
      timeout) PROV_CREATE_FATAL_MSG="create timed out for $candidate" ;;
      err:*)   PROV_CREATE_FATAL_MSG="${result#err:}" ;;
      *)       PROV_CREATE_FATAL_MSG="unexpected: $result" ;;
    esac
  done
  # Close: cursor on line 1, delete all 4 lines.
  printf '\033[4M'
  if [ "$up" -gt 0 ]; then
    printf '\033[%dB\r' "$up"
  fi
  [ -n "$PROV_CREATE_FATAL_MSG" ] && return 1
  return 0
}

