# 11. GCP/FIREBASE REST PLUMBING
# =====================================================================

json_extract() {
  grep -oE "\"$1\"[[:space:]]*:[[:space:]]*\"[^\"]+\"" | head -1 \
    | sed -E "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"([^\"]+)\".*/\1/"
}

op_name_from() {
  printf '%s' "$1" | grep -oE '"name"[[:space:]]*:[[:space:]]*"[^"]+' \
    | head -1 | sed 's/.*"\([^"]*\)$/\1/'
}

# Cheap pre-flight: do they have an OPEN billing account (free-trial or paid)?
# Sets PREFLIGHT_REASON on failure ("no_billing" | "billing_check_failed").
# Firebase ToS is detected later in add_firebase — there's no clean
# read-only probe for it.
PREFLIGHT_REASON=""
preflight_check() {
  PREFLIGHT_REASON=""
  local resp
  if ! resp=$(curl -fsSL -H "Authorization: Bearer $ACCESS_TOKEN" \
      "https://cloudbilling.googleapis.com/v1/billingAccounts" 2>&1); then
    PREFLIGHT_REASON="billing_check_failed"
    http_log "preflight: billing list failed: $resp"
    return 1
  fi
  if ! grep -q '"open"[[:space:]]*:[[:space:]]*true' <<< "$resp"; then
    PREFLIGHT_REASON="no_billing"
    http_log "preflight: no open billing account"
    return 1
  fi
  return 0
}

# Wait for a Google long-running operation. $1 = full op URL, $2 = timeout sec.
# Caller can set X_GOOG_USER_PROJECT to add the X-Goog-User-Project header
# (required for Firebase/Identity APIs once enabled on the project).
wait_for_op() {
  local url="$1" timeout="${2:-60}"
  local i resp code hdr=()
  if [ -n "${X_GOOG_USER_PROJECT:-}" ]; then
    hdr=(-H "X-Goog-User-Project: $X_GOOG_USER_PROJECT")
  fi
  http_log "wait_for_op start: $url (timeout=${timeout}s, X-Goog-User-Project=${X_GOOG_USER_PROJECT:-<none>})"
  for i in $(seq 1 "$timeout"); do
    local tmp; tmp=$(mktemp)
    code=$(curl -s -o "$tmp" -w "%{http_code}" \
      -H "Authorization: Bearer $ACCESS_TOKEN" "${hdr[@]}" "$url")
    resp=$(cat "$tmp"); rm -f "$tmp"
    http_log "  poll #$i HTTP $code: $(log_trunc "$resp")"
    if [ "$code" != "200" ]; then
      http_log "wait_for_op aborting: non-200 status from poll"
      return 1
    fi
    if grep -q '"done"[[:space:]]*:[[:space:]]*true' <<< "$resp"; then
      if grep -q '"error"' <<< "$resp"; then
        http_log "wait_for_op error from $url"
        return 1
      fi
      http_log "wait_for_op done after $i polls"
      return 0
    fi
    sleep 1
  done
  http_log "wait_for_op timeout after ${timeout}s: $url last_resp: $(log_trunc "$resp")"
  return 1
}

# Extract a JSON error.message from an API response body. Empty
# string on parse failure. Used to surface verbatim Google errors so
# the user sees the real reason instead of a generic "HTTP 403".
_extract_error_message() {
  perl -MJSON::PP -e 'eval { my $j = decode_json(do { local $/; <STDIN> }); print $j->{error}{message} // $j->{response}{error}{message} // ""; 1 } or print ""'
}

# Create a GCP project and wait for the LRO. Prints one of:
#   ok | taken | quota | timeout | err:<verbatim message>
create_project() {
  local pid="$1"
  local tmp; tmp=$(mktemp)
  local code
  code=$(curl -s -o "$tmp" -w "%{http_code}" \
    -X POST \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -H "Content-Type: application/json" \
    -d "{\"projectId\":\"$pid\",\"displayName\":\"$pid\"}" \
    "https://cloudresourcemanager.googleapis.com/v3/projects")
  local body; body=$(cat "$tmp"); rm -f "$tmp"
  http_log "create_project $pid → HTTP $code body: $(log_trunc "$body")"

  if [ "$code" = "409" ] || grep -qi 'already.*exists\|ALREADY_EXISTS' <<< "$body"; then
    printf '%s' "taken"; return
  fi
  if grep -qiE 'RESOURCE_EXHAUSTED|maximum.*number.*of.*projects|project.*limit|quota' <<< "$body"; then
    printf '%s' "quota"; return
  fi
  if [ "$code" != "200" ] && [ "$code" != "201" ]; then
    local msg
    msg=$(printf '%s' "$body" | _extract_error_message)
    [ -z "$msg" ] && msg="HTTP $code: $(log_trunc "$body")"
    printf 'err:%s' "$msg"; return
  fi

  local op_name; op_name=$(op_name_from "$body")
  if [ -z "$op_name" ]; then
    printf 'err:no operation name in create response: %s' "$(log_trunc "$body")"
    return
  fi

  local i resp
  for i in $(seq 1 60); do
    sleep 1
    resp=$(curl -s -H "Authorization: Bearer $ACCESS_TOKEN" \
      "https://cloudresourcemanager.googleapis.com/v3/$op_name")
    if grep -q '"done"[[:space:]]*:[[:space:]]*true' <<< "$resp"; then
      if grep -q '"error"' <<< "$resp"; then
        if grep -qi 'already.*exists\|ALREADY_EXISTS' <<< "$resp"; then
          printf '%s' "taken"; return
        fi
        if grep -qiE 'RESOURCE_EXHAUSTED|maximum.*number.*of.*projects|project.*limit|quota' <<< "$resp"; then
          printf '%s' "quota"; return
        fi
        local msg
        msg=$(printf '%s' "$resp" | _extract_error_message)
        [ -z "$msg" ] && msg="$(log_trunc "$resp")"
        printf 'err:%s' "$msg"
        return
      fi
      printf '%s' "ok"; return
    fi
  done
  printf '%s' "timeout"
}

# Check that the caller can read the given project. Used by
# --reuse-project to fail fast when the user passes a project id that
# doesn't exist or that this account can't see.
project_exists() {
  local pid="$1"
  local code
  code=$(curl -s -o /dev/null -w "%{http_code}" \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    "https://cloudresourcemanager.googleapis.com/v3/projects/$pid")
  http_log "project_exists $pid → HTTP $code"
  [ "$code" = "200" ]
}

# Enable a single API. first=1 skips X-Goog-User-Project (chicken-and-egg
# on a fresh project that has no APIs to bill quota to yet).
enable_api() {
  local pid="$1" api="$2" first="${3:-0}"
  local hdr=(-H "Authorization: Bearer $ACCESS_TOKEN" -H "Content-Type: application/json")
  [ "$first" != "1" ] && hdr+=(-H "X-Goog-User-Project: $pid")

  http_log "enable_api start: pid=$pid api=$api first=$first"
  local tmp; tmp=$(mktemp)
  local code
  code=$(curl -s -o "$tmp" -w "%{http_code}" -X POST "${hdr[@]}" \
    "https://serviceusage.googleapis.com/v1/projects/$pid/services/$api:enable")
  local body; body=$(cat "$tmp"); rm -f "$tmp"
  http_log "enable_api $api → HTTP $code body: $(log_trunc "$body")"

  if [ "$code" != "200" ]; then return 1; fi
  # Already-enabled services return operations/noop.DONE_OPERATION with
  # done:true right in the response — that's NOT a real op, polling
  # 400s with "Invalid operation id". Treat done:true as success.
  if grep -q '"done"[[:space:]]*:[[:space:]]*true' <<< "$body"; then
    http_log "enable_api $api: completed synchronously (already enabled)"
    return 0
  fi
  local op_name; op_name=$(op_name_from "$body")
  http_log "enable_api $api op_name='$op_name'"
  if [ -n "$op_name" ]; then
    if [ "$first" = "1" ]; then
      wait_for_op "https://serviceusage.googleapis.com/v1/$op_name" 120
    else
      X_GOOG_USER_PROJECT="$pid" wait_for_op "https://serviceusage.googleapis.com/v1/$op_name" 120
    fi
  else
    http_log "enable_api $api: no op_name; treating POST 200 as success"
  fi
}

# Link an open billing account to a project. preflight_check has
# already verified at least one open account exists; this attaches the
# first one so billing-required APIs (Cloud Build / Run / Artifact
# Registry / etc) can be enabled. Idempotent.
link_billing() {
  local pid="$1"
  http_log "link_billing start: pid=$pid"

  local cur_resp
  cur_resp=$(curl -s \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    "https://cloudbilling.googleapis.com/v1/projects/$pid/billingInfo")
  http_log "link_billing $pid current: $(log_trunc "$cur_resp")"
  if grep -q '"billingEnabled"[[:space:]]*:[[:space:]]*true' <<< "$cur_resp"; then
    http_log "link_billing $pid: already linked, skipping"
    return 0
  fi

  local accounts_resp
  accounts_resp=$(curl -s \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    "https://cloudbilling.googleapis.com/v1/billingAccounts")
  http_log "link_billing $pid accounts: $(log_trunc "$accounts_resp")"
  local account_name
  account_name=$(ACCOUNTS="$accounts_resp" perl -MJSON::PP -e '
    my $j = decode_json($ENV{ACCOUNTS});
    for my $a (@{$j->{billingAccounts} // []}) {
      if ($a->{open}) { print $a->{name}; last; }
    }
  ')
  if [ -z "$account_name" ]; then
    http_log "link_billing $pid: no open billing account found"
    return 1
  fi
  http_log "link_billing $pid: linking $account_name"

  local tmp; tmp=$(mktemp)
  local code
  code=$(curl -s -o "$tmp" -w "%{http_code}" -X PUT \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -H "Content-Type: application/json" \
    -d "{\"billingAccountName\":\"$account_name\"}" \
    "https://cloudbilling.googleapis.com/v1/projects/$pid/billingInfo")
  local body; body=$(cat "$tmp"); rm -f "$tmp"
  http_log "link_billing $pid PUT → HTTP $code body: $(log_trunc "$body")"
  if [ "$code" != "200" ]; then return 1; fi
}

# Convert a GCP project to a Firebase project. On failure, sets one of:
#   ADD_FIREBASE_FATAL_REASON=no_firebase_tos    — user hasn't accepted ToS
#   ADD_FIREBASE_FATAL_MSG="..."                 — anything else, with a
#                                                  specific one-liner the
#                                                  row UI can print verbatim.
ADD_FIREBASE_FATAL_REASON=""
ADD_FIREBASE_FATAL_MSG=""

# Returns 0 if HTTP/body looks like the Firebase Management API hasn't
# propagated yet after enable_api. Google's own message instructs us to
# wait a few minutes — typically 30–90s after the enable op returns done.
_is_service_disabled() {
  local code="$1" body="$2"
  [ "$code" = "403" ] && grep -q 'SERVICE_DISABLED\|has not been used in project' <<< "$body"
}

add_firebase() {
  local pid="$1"
  ADD_FIREBASE_FATAL_REASON=""
  ADD_FIREBASE_FATAL_MSG=""

  http_log "add_firebase start: pid=$pid"

  # Skip-check: GET projects/$pid. 200 = already Firebase (skip);
  # 404 = API live but not Firebase yet (proceed to POST);
  # 403 SERVICE_DISABLED = enable_api propagation lag — retry.
  local check_code check_body i
  for i in $(seq 1 15); do
    local check_tmp; check_tmp=$(mktemp)
    check_code=$(curl -s -o "$check_tmp" -w "%{http_code}" \
      -H "Authorization: Bearer $ACCESS_TOKEN" \
      -H "X-Goog-User-Project: $pid" \
      "https://firebase.googleapis.com/v1beta1/projects/$pid")
    check_body=$(cat "$check_tmp"); rm -f "$check_tmp"
    http_log "add_firebase $pid skip-check #$i → HTTP $check_code body: $(log_trunc "$check_body")"
    [ "$check_code" = "200" ] && { http_log "add_firebase $pid: already Firebase, skipping"; return 0; }
    if _is_service_disabled "$check_code" "$check_body"; then sleep 6; continue; fi
    break
  done

  # POST :addFirebase, also tolerating SERVICE_DISABLED propagation. The
  # GET above can succeed (404) while the POST still 403s — both endpoints
  # propagate independently.
  local code body
  for i in $(seq 1 15); do
    local tmp; tmp=$(mktemp)
    code=$(curl -s -o "$tmp" -w "%{http_code}" -X POST \
      -H "Authorization: Bearer $ACCESS_TOKEN" \
      -H "X-Goog-User-Project: $pid" \
      -H "Content-Type: application/json" \
      -d '{}' \
      "https://firebase.googleapis.com/v1beta1/projects/$pid:addFirebase")
    body=$(cat "$tmp"); rm -f "$tmp"
    http_log "add_firebase $pid POST #$i → HTTP $code body: $(log_trunc "$body")"
    [ "$code" = "200" ] && break
    if _is_service_disabled "$code" "$body"; then sleep 6; continue; fi
    break
  done

  if [ "$code" = "400" ] && grep -qi 'terms.of.service\|console\.developers\.google\.com/terms' <<< "$body"; then
    ADD_FIREBASE_FATAL_REASON="no_firebase_tos"
    return 1
  fi
  if _is_service_disabled "$code" "$body"; then
    ADD_FIREBASE_FATAL_MSG="Firebase Management API enablement still propagating after 90s — re-run in a minute or two"
    return 1
  fi
  if [ "$code" != "200" ]; then
    ADD_FIREBASE_FATAL_MSG="addFirebase failed with HTTP $code — see $HTTP_LOG"
    return 1
  fi
  local op_name; op_name=$(op_name_from "$body")
  http_log "add_firebase $pid op_name='$op_name'"
  if [ -z "$op_name" ]; then
    ADD_FIREBASE_FATAL_MSG="addFirebase returned no op name — see $HTTP_LOG"
    return 1
  fi
  X_GOOG_USER_PROJECT="$pid" wait_for_op "https://firebase.googleapis.com/v1beta1/$op_name" 120
}

# Create a Firebase web app config so the SvelteKit client can call
# initializeApp({...}). The webApp's apiKey/appId are fetched later
# (during clone+deploy) via webApps.list + webApps.getConfig.
create_web_app() {
  local pid="$1"

  http_log "create_web_app start: pid=$pid"
  local list_resp
  list_resp=$(curl -s \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -H "X-Goog-User-Project: $pid" \
    "https://firebase.googleapis.com/v1beta1/projects/$pid/webApps")
  http_log "create_web_app $pid skip-check list: $(log_trunc "$list_resp")"
  if grep -q '"appId"' <<< "$list_resp"; then
    http_log "create_web_app $pid: web app exists, skipping"
    return 0
  fi

  local tmp; tmp=$(mktemp)
  local code
  code=$(curl -s -o "$tmp" -w "%{http_code}" -X POST \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -H "X-Goog-User-Project: $pid" \
    -H "Content-Type: application/json" \
    -d '{"displayName":"web"}' \
    "https://firebase.googleapis.com/v1beta1/projects/$pid/webApps")
  local body; body=$(cat "$tmp"); rm -f "$tmp"
  http_log "create_web_app $pid → HTTP $code body: $(log_trunc "$body")"
  if [ "$code" != "200" ]; then return 1; fi
  local op_name; op_name=$(op_name_from "$body")
  http_log "create_web_app $pid op_name='$op_name'"
  [ -z "$op_name" ] && return 1
  X_GOOG_USER_PROJECT="$pid" wait_for_op "https://firebase.googleapis.com/v1beta1/$op_name" 120
}

# Create the (default) Firestore database in $REGION, NATIVE mode.
create_firestore() {
  local pid="$1"

  http_log "create_firestore start: pid=$pid"
  local check_tmp; check_tmp=$(mktemp)
  local check_code
  check_code=$(curl -s -o "$check_tmp" -w "%{http_code}" \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -H "X-Goog-User-Project: $pid" \
    "https://firestore.googleapis.com/v1/projects/$pid/databases/(default)")
  local check_body; check_body=$(cat "$check_tmp"); rm -f "$check_tmp"
  http_log "create_firestore $pid skip-check → HTTP $check_code body: $(log_trunc "$check_body")"
  if [ "$check_code" = "200" ]; then
    # Existing DB (e.g. --reuse-project): its region is fixed and authoritative.
    # Adopt it as REGION so .env records the truth, not whatever --region said.
    local existing_region
    existing_region=$(printf '%s' "$check_body" | json_extract locationId)
    [ -n "$existing_region" ] && REGION="$existing_region"
    http_log "create_firestore $pid: (default) exists in '$REGION', skipping create"
    return 0
  fi

  local tmp; tmp=$(mktemp)
  local code
  code=$(curl -s -o "$tmp" -w "%{http_code}" -X POST \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -H "X-Goog-User-Project: $pid" \
    -H "Content-Type: application/json" \
    -d "{\"locationId\":\"$REGION\",\"type\":\"FIRESTORE_NATIVE\"}" \
    "https://firestore.googleapis.com/v1/projects/$pid/databases?databaseId=(default)")
  local body; body=$(cat "$tmp"); rm -f "$tmp"
  http_log "create_firestore $pid → HTTP $code body: $(log_trunc "$body")"
  if [ "$code" != "200" ]; then return 1; fi
  local op_name; op_name=$(op_name_from "$body")
  http_log "create_firestore $pid op_name='$op_name'"
  [ -z "$op_name" ] && return 1
  X_GOOG_USER_PROJECT="$pid" wait_for_op "https://firestore.googleapis.com/v1/$op_name" 180
}

# Create the default Firebase Storage bucket in $REGION.
create_storage_bucket() {
  local pid="$1"

  http_log "create_storage_bucket start: pid=$pid"
  local list_resp
  list_resp=$(curl -s \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -H "X-Goog-User-Project: $pid" \
    "https://firebasestorage.googleapis.com/v1beta/projects/$pid/buckets")
  http_log "create_storage_bucket $pid skip-check list: $(log_trunc "$list_resp")"
  if grep -q '"bucket"' <<< "$list_resp"; then
    http_log "create_storage_bucket $pid: bucket exists, skipping"
    return 0
  fi

  local tmp; tmp=$(mktemp)
  local code
  code=$(curl -s -o "$tmp" -w "%{http_code}" -X POST \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -H "X-Goog-User-Project: $pid" \
    -H "Content-Type: application/json" \
    -d "{\"location\":\"$REGION\"}" \
    "https://firebasestorage.googleapis.com/v1beta/projects/$pid/defaultBucket")
  local body; body=$(cat "$tmp"); rm -f "$tmp"
  http_log "create_storage_bucket $pid → HTTP $code body: $(log_trunc "$body")"
  if [ "$code" != "200" ]; then return 1; fi
  local op_name; op_name=$(op_name_from "$body")
  http_log "create_storage_bucket $pid op_name='$op_name'"
  if [ -n "$op_name" ] && [[ "$op_name" == *operations/* ]]; then
    X_GOOG_USER_PROJECT="$pid" wait_for_op "https://firebasestorage.googleapis.com/v1beta/$op_name" 120
  fi
}

# Configure Firebase Auth providers via Identity Toolkit. Enables
# anonymous + email-link sign-in and appends "localhost" to
# authorizedDomains so email links work in local dev (projects created
# after 2025-04-28 don't include localhost by default).
configure_auth() {
  local pid="$1"
  http_log "configure_auth start: pid=$pid"

  # The Identity Toolkit Config resource doesn't exist until first
  # PATCH — GET can return 404 even on a project where the API is
  # enabled. Inspect the code rather than -fsSL'ing out on 404.
  local cur_tmp; cur_tmp=$(mktemp)
  local cur cur_code
  cur_code=$(curl -s -o "$cur_tmp" -w "%{http_code}" \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -H "X-Goog-User-Project: $pid" \
    "https://identitytoolkit.googleapis.com/admin/v2/projects/$pid/config")
  cur=$(cat "$cur_tmp"); rm -f "$cur_tmp"
  http_log "configure_auth $pid GET → HTTP $cur_code body: $(log_trunc "$cur")"

  # On 404 (fresh project), initializeAuth bootstraps onto Identity
  # Platform (free tier: 50K MAU/month). Anonymous + email-link sign-in
  # both work the same as on plain Firebase Auth. PATCH alone won't —
  # returns CONFIGURATION_NOT_FOUND.
  if [ "$cur_code" = "404" ]; then
    http_log "configure_auth $pid: initializing Identity Platform"
    local init_tmp; init_tmp=$(mktemp)
    local init_code init_body
    init_code=$(curl -s -o "$init_tmp" -w "%{http_code}" -X POST \
      -H "Authorization: Bearer $ACCESS_TOKEN" \
      -H "X-Goog-User-Project: $pid" \
      -H "Content-Type: application/json" \
      -d '{}' \
      "https://identitytoolkit.googleapis.com/v2/projects/$pid/identityPlatform:initializeAuth")
    init_body=$(cat "$init_tmp"); rm -f "$init_tmp"
    http_log "configure_auth $pid initializeAuth → HTTP $init_code body: $(log_trunc "$init_body")"
    if [ "$init_code" != "200" ]; then return 1; fi

    cur_tmp=$(mktemp)
    cur_code=$(curl -s -o "$cur_tmp" -w "%{http_code}" \
      -H "Authorization: Bearer $ACCESS_TOKEN" \
      -H "X-Goog-User-Project: $pid" \
      "https://identitytoolkit.googleapis.com/admin/v2/projects/$pid/config")
    cur=$(cat "$cur_tmp"); rm -f "$cur_tmp"
    http_log "configure_auth $pid GET (post-init) → HTTP $cur_code body: $(log_trunc "$cur")"
    if [ "$cur_code" != "200" ]; then return 1; fi
  elif [ "$cur_code" != "200" ]; then
    http_log "configure_auth: unexpected GET status $cur_code"
    return 1
  fi

  local domains_json
  domains_json=$(CUR="$cur" perl -MJSON::PP -e '
    my $j = decode_json($ENV{CUR});
    my @d = @{$j->{authorizedDomains} // []};
    push @d, "localhost" unless grep { $_ eq "localhost" } @d;
    print encode_json(\@d);
  ') || { http_log "configure_auth: domain merge failed"; return 1; }

  local body
  body=$(printf '{"signIn":{"anonymous":{"enabled":true},"email":{"enabled":true,"passwordRequired":false}},"authorizedDomains":%s}' "$domains_json")

  local tmp; tmp=$(mktemp)
  local code
  code=$(curl -s -o "$tmp" -w "%{http_code}" -X PATCH \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -H "X-Goog-User-Project: $pid" \
    -H "Content-Type: application/json" \
    -d "$body" \
    "https://identitytoolkit.googleapis.com/admin/v2/projects/$pid/config?updateMask=signIn.anonymous,signIn.email,authorizedDomains")
  local resp; resp=$(cat "$tmp"); rm -f "$tmp"
  http_log "configure_auth $pid → HTTP $code body: $(log_trunc "$resp")"
  if [ "$code" != "200" ]; then return 1; fi
}

# Validate a GCP project ID. Collects ALL violated rules so the user
# sees every rule they're breaking at once, not just the first.
VALIDATION_ERRORS=()
validate_gcp_project_id() {
  local id="$1"
  VALIDATION_ERRORS=()
  if [ -z "$id" ]; then
    VALIDATION_ERRORS+=("cannot be empty")
    return 1
  fi
  if [ "${#id}" -lt 6 ];            then VALIDATION_ERRORS+=("6 char min"); fi
  if [ "${#id}" -gt 30 ];           then VALIDATION_ERRORS+=("30 char max"); fi
  if [[ ! "$id" =~ ^[a-z] ]];       then VALIDATION_ERRORS+=("must start with a letter"); fi
  if [[ "$id" =~ -- ]];             then VALIDATION_ERRORS+=("no double dashes"); fi
  if [[ "$id" =~ -$ ]];             then VALIDATION_ERRORS+=("cannot end with a dash"); fi
  if [[ ! "$id" =~ ^[a-z0-9-]+$ ]]; then VALIDATION_ERRORS+=("lowercase letters, digits, dashes only"); fi
  if [ ${#VALIDATION_ERRORS[@]} -gt 0 ]; then return 1; fi
  return 0
}

# Print setup-needed instructions when preflight (no_billing) or
# add_firebase (no_firebase_tos) detects an account that hasn't
# completed its one-time Firebase Console setup.
print_setup_needed() {
  local email="$1" reason="$2"
  echo ""
  case "$reason" in
    no_firebase_tos)
      echo "✗ Firebase Terms of Service not accepted yet for $email."
      echo ""
      echo "  Fastest fix: open Firebase Console and start their"
      echo "  'create a project' flow once. It bundles ToS acceptance."
      echo ""
      echo "  https://console.firebase.google.com/"
      ;;
    no_billing)
      echo "✗ No billing account set up yet for $email."
      echo ""
      echo "  Fastest fix: open Firebase Console, click Create a project,"
      echo "  accept the free trial when prompted."
      echo ""
      echo "  https://console.firebase.google.com/"
      ;;
    *)
      echo "✗ Setup issue for $email: $reason"
      ;;
  esac
  echo ""
  echo "Then re-run this script."
  echo ""
}

