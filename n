draw_prov_row() {
  local i="$1" state="$2"
  local icon label
  case "$state" in
    done)    icon="✓   "; label="${PROV_DONE[$i]}"    ;;
    running) icon="--->"; label="${PROV_RUNNING[$i]}" ;;
    pending) icon="○   "; label="${PROV_PENDING[$i]}" ;;
    failed)  icon="✗   "; label="${PROV_RUNNING[$i]}" ;;
  esac
  printf '%s  %s\n' "$icon" "$label"
}

update_prov_row() {
  local i="$1" state="$2"
  local up=$((PROV_N - i))
  printf '\033[%dA\r\033[K' "$up"
  draw_prov_row "$i" "$state"
  local down=$((PROV_N - i - 1))
  if [ "$down" -gt 0 ]; then
    printf '\033[%dB\r' "$down"
  fi
}

PROV_SIGNIN_PREFLIGHT_FAIL=""

provision_all() {
  local i fn rc
  for i in $(seq 0 $((PROV_N - 1))); do
    draw_prov_row "$i" "pending"
  done
  for i in "${!PROV_FNS[@]}"; do
    fn="${PROV_FNS[$i]}"
    update_prov_row "$i" "running"
    rc=0
    "$fn" || rc=$?
    if [ "$rc" -eq 0 ]; then
      update_prov_row "$i" "done"
    else
      update_prov_row "$i" "failed"
      echo ""
      echo ""
      if [ "$fn" = "_prov_signin" ]; then
        if [ -n "$PROV_SIGNIN_PREFLIGHT_FAIL" ]; then
          # Sign-in succeeded but billing preflight failed — surface the
          # one-time-setup hint with the right reason.
          print_setup_needed "$EMAIL" "$PROV_SIGNIN_PREFLIGHT_FAIL"
        else
          # cmd-auth.mjs returned non-zero — almost always the 5-min
          # browser-consent timeout.
          echo "✗  we waited 5 mins for sign-in .. re-run when you're ready"
        fi
      elif [ "$fn" = "_prov_create" ] && [ -n "$PROV_CREATE_FATAL_MSG" ]; then
        echo "✗  $PROV_CREATE_FATAL_MSG"
      elif [ "$fn" = "_prov_add_firebase" ]; then
        if [ "$ADD_FIREBASE_FATAL_REASON" = "no_firebase_tos" ]; then
          print_setup_needed "$EMAIL" "no_firebase_tos"
        elif [ -n "$ADD_FIREBASE_FATAL_MSG" ]; then
          echo "✗  $ADD_FIREBASE_FATAL_MSG"
        else
          echo "✗  failed to add firebase — see $HTTP_LOG for details"
        fi
      else
        echo "✗  $fn failed — see $HTTP_LOG for details"
      fi
      echo ""
      echo ""
      # Clean message already shown — suppress the EXIT-trap log dump.
      trap - EXIT
      exit 1
    fi
  done
}

