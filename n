# Generate a 3-word dash-joined passphrase, e.g. "bath-tree-cone". Used
# to seed the bouncer secret in functions/.env. $RANDOM is fine here —
# see the entropy note on PASSPHRASE_WORDS.
_gen_passphrase() {
  local words i out=
  words=( $PASSPHRASE_WORDS )
  for i in 1 2 3; do
    out="${out:+$out-}${words[RANDOM % ${#words[@]}]}"
  done
  printf '%s' "$out"
}

# Seed functions/.env from the template's functions/.env.example — it
# carries every key the functions runtime expects (bouncer secret, OAuth
# consent id/key, ADMIN_CONSENTS), so copying keeps n in sync as the
# template grows keys. The OAuth/consent keys stay as the example's empty
# placeholders (they need real Cloud Console values), but we fill the
# bouncer secret with a generated 3-word passphrase so the project's
# inbound endpoints aren't wide open on day one. If the template ever
# renames the bouncer key, the sed below silently no-ops — re-check it.
# .env is gitignored so secrets never reach the repo.
_write_functions_env() {
  local key="CODE_THAT_OTHER_SERVICES_NEED_TO_GET_PAST_OUR_BOUNCER"
  cp "$PROJECT_PATH/functions/.env.example" "$PROJECT_PATH/functions/.env"
  sed -i '' "s/^$key=\$/$key=$(_gen_passphrase)/" "$PROJECT_PATH/functions/.env"
}

# Seed the project owner's email into Firestore's `users` collection so
# they can sign in to /admin on day one. firestore.rules require an
# existing membership before allowing reads/writes — without this seed
# the first user is locked out. The OAuth bearer token has cloud-platform
# scope (admin), bypasses security rules. 200 = created, 409 = already
# exists (treated as success so re-runs are no-ops).
#
# Schema mirrored by hand from the template's canonical zod schema at
# functions/src/common/User.ts (and the matching cmd-seed-user.mjs the
# emulator uses). If you change User.ts, mirror the change here too.
#   doc id: lowercased email
#   fields: { email, admin, addedAt (ms epoch), addedBy }
# `addedBy` is "bootstrap" (not the owner's email) to reflect that this
# row was written by automation, not by a person on the /admin page.
_seed_user() {
  local email_lc now_ms body code
  email_lc=$(printf '%s' "$EMAIL" | tr '[:upper:]' '[:lower:]')
  now_ms=$(($(date +%s) * 1000))
  body=$(printf '{"fields":{"email":{"stringValue":"%s"},"admin":{"booleanValue":true},"addedAt":{"integerValue":"%d"},"addedBy":{"stringValue":"bootstrap"}}}' \
    "$email_lc" "$now_ms")
  code=$(curl -s -o /dev/null -w "%{http_code}" -X POST \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -H "X-Goog-User-Project: $PID" \
    -H "Content-Type: application/json" \
    --data "$body" \
    "https://firestore.googleapis.com/v1/projects/$PID/databases/(default)/documents/users?documentId=$email_lc")
  http_log "_seed_user: HTTP $code for users/$email_lc"
  case "$code" in
    200|409) return 0 ;;
    *) return 1 ;;
  esac
}

_install_deps() { ( cd "$PROJECT_PATH" && npm run install:all ); }

# `npm run deploy` invokes cmd-deploy.mjs (a thin firebase-tools
# wrapper). It reads THIS_PROJECT_ID_ON_GOOGLE_HOSTING from .env,
# synthesizes ADC creds from .env.auth.json, then shells out to
# firebase-tools (which builds via firebase.json predeploy + pushes
# hosting / firestore rules + indexes / storage rules / functions).
_deploy_to_fb() {
  ( cd "$PROJECT_PATH" && npm run deploy )
}

# --- row UI for the deploy phase ---

DEPLOY_PENDING=(
  "downloading project template"
  "tailoring project settings"
  "deploying project"
)
DEPLOY_RUNNING=(
  "downloading project template"
  "tailoring project settings"
  "deploying project"
)
DEPLOY_DONE=(
  "project template downloaded"
  "project settings tailored"
  "project deployed"
)
DEPLOY_FNS=(
  "_dep_download"
  "_dep_tailor"
  "_dep_deploy"
)
DEPLOY_N=${#DEPLOY_PENDING[@]}

_dep_download() { _clone_template && _move_auth_cred; }
_dep_tailor()   { _write_env && _write_client_env && _write_functions_env && _seed_user && _trust_path "$PROJECT_PATH"; }
_dep_deploy()   { _install_deps && _deploy_to_fb; }

draw_dep_row() {
  local i="$1" state="$2"
  local icon label
  case "$state" in
    done)    icon="✓   "; label="${DEPLOY_DONE[$i]}"    ;;
    running) icon="--->"; label="${DEPLOY_RUNNING[$i]}" ;;
    pending) icon="○   "; label="${DEPLOY_PENDING[$i]}" ;;
    failed)  icon="✗   "; label="${DEPLOY_RUNNING[$i]}" ;;
  esac
  printf '%s  %s\n' "$icon" "$label"
}

update_dep_row() {
  local i="$1" state="$2"
  local up=$((DEPLOY_N - i))
  printf '\033[%dA\r\033[K' "$up"
  draw_dep_row "$i" "$state"
  local down=$((DEPLOY_N - i - 1))
  if [ "$down" -gt 0 ]; then
    printf '\033[%dB\r' "$down"
  fi
}

deploy_all() {
  local i fn rc
  for i in $(seq 0 $((DEPLOY_N - 1))); do
    draw_dep_row "$i" "pending"
  done
  for i in "${!DEPLOY_FNS[@]}"; do
    fn="${DEPLOY_FNS[$i]}"
    update_dep_row "$i" "running"
    rc=0
    "$fn" >> "$HTTP_LOG" 2>&1 || rc=$?
    if [ "$rc" -eq 0 ]; then
      update_dep_row "$i" "done"
    else
      update_dep_row "$i" "failed"
      echo ""
      echo ""
      echo "✗  ${DEPLOY_PENDING[$i]} failed — see $HTTP_LOG for details"
      echo ""
      echo ""
      trap - EXIT
      exit 1
    fi
  done
}

echo ""
echo "creating and deploying your project to google hosting"
echo ""
deploy_all

